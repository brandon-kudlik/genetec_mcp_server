# Path to Genetec Security Center SDK DLLs (net8.0-windows assemblies)
GENETEC_SDK_PATH=C:\Program Files (x86)\Genetec Security Center 5.13 SDK\net8.0-windows

# Path for Genetec .gconfig files (created automatically if missing)
GENETEC_CONFIG_PATH=C:\ProgramData\Genetec Security Center 5.13

# Security Center Directory server
GENETEC_SERVER=localhost

# Credentials (leave empty to use Windows authentication)
GENETEC_USERNAME=
GENETEC_PASSWORD=

# SDK client certificate ApplicationId (development cert used by default)
# GENETEC_CLIENT_CERTIFICATE=KxsD11z743Hf5Gq9mv3+5ekxzemlCiUXkTFY5ba1NOGcLCmGstt2n0zYE9NsNimv
